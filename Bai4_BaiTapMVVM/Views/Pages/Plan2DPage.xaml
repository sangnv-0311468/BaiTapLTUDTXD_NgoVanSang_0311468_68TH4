<Page x:Class="Bai4_BaiTapMVVM.Views.Pages.Plan2DPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Bai4_BaiTapMVVM.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Plan2DPage">

    <Grid>
        <Canvas Background="LightGray">
            <Rectangle Width="200" Height="100" Fill="Blue" Canvas.Left="100" Canvas.Top="100"/>
            <Ellipse Width="100" Height="100" Fill="Red" Canvas.Left="350" Canvas.Top="150"/>
            <Line X1="50" Y1="50" X2="400" Y2="300" Stroke="Black" StrokeThickness="2"/>
        </Canvas>
    </Grid>
</Page>
