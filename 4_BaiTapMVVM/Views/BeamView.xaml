<Window x:Class="_4_BaiTapMVVM.Views.BeamView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_4_BaiTapMVVM.Views"
         xmlns:beamviewmodel="clr-namespace:_4_BaiTapMVVM.ViewModels"
        mc:Ignorable="d"
           Title="BeamView" Height="450" Width="800">
    <Window.DataContext>
        <beamviewmodel:BeamViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" 
              ItemsSource="{Binding Beams}" 
              AutoGenerateColumns="False" 
              Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Mark" Binding="{Binding Mark}" Width="*"/>
                <DataGridTextColumn Header="Story" Binding="{Binding Story}" Width="*"/>
                <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="*"/>
                <DataGridTextColumn Header="Volume" Binding="{Binding Volume}" Width="Auto"/>
            </DataGrid.Columns>

        </DataGrid>

        <Button x:Name="btn_AddBeam"
            Content="Add Beam"
            Grid.Row="1" Height="30"
            Width="100" 
            Command="{Binding AddBeamCommand}">

        </Button>
    </Grid>
</Window>
