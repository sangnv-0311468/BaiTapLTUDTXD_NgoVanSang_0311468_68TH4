<Window x:Class="Bai2_TaoMenuRibbon_Usercontrol_Pages.Views.KetnoiEtabs"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bai2_TaoMenuRibbon_Usercontrol_Pages.Views"
        mc:Ignorable="d"
           Title="Kết nối Etabs" Height="150" Width="300">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="20">
            <TextBlock Name="lblStatus" Text="Đang kết nối với Etabs..." 
           FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <ProgressBar Name="pgBar" Height="15" Width="300" 
             Minimum="0" Maximum="100" 
             Foreground="#FF007ACC" Background="#FFE6E6E6"/>
        </StackPanel>
    </Grid>
</Window>
