<Window x:Class="Bai2_TaoMenuRibbon_Usercontrol_Pages.Views.Khaibaodiachat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bai2_TaoMenuRibbon_Usercontrol_Pages.Views"
        mc:Ignorable="d"
           Title="Khaibaodiachat" Height="450" Width="870">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="Lớp đất:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="0" Grid.Column="1" Margin="5" >
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/>
                <ComboBoxItem Content="4"/>
                <ComboBoxItem Content="5"/>
                <ComboBoxItem Content="6"/>
                <ComboBoxItem Content="7"/>
            </ComboBox>
            <Label Grid.Row="1" Grid.Column="0" Content="φ:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="5"/>
            <Label Grid.Row="2" Grid.Column="0" Content="Chiều dày(m):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Margin="5"/>
            <Label Grid.Row="3" Grid.Column="0" Content="γ(kN/m³):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="3" Grid.Column="1" Margin="5" />
            <Label Grid.Row="4" Grid.Column="0" Content="Độ dính C(kN/m²):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1" Margin="5"/>
            <Label Grid.Row="5" Grid.Column="0" Content="Moodun E(kN/m²):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="5" Grid.Column="1" Margin="5"/>
            <Label HorizontalAlignment="Center" Grid.Row="0" Grid.Column="2" Content="W(%):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="3" Margin="5"/>
            <Label HorizontalAlignment="Center" Grid.Row="1" Grid.Column="2" Content="Wd(%):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="3" Margin="5"/>
            <Label HorizontalAlignment="Center" Grid.Row="2" Grid.Column="2" Content="Wch(%):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="3" Margin="5"/>
            <Label HorizontalAlignment="Center" Grid.Row="3" Grid.Column="2" Content="N(SPT):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="3" Grid.Column="3" Margin="5"/>
            <Label HorizontalAlignment="Center" Grid.Row="4" Grid.Column="2" Content="qc(CPT):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="3" Margin="5"/>
            <Label HorizontalAlignment="Center" Grid.Row="5" Grid.Column="2" Content="Δ:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="5" Grid.Column="3" Margin="5"/>
            <Button Grid.Row="4" Grid.Column="4"
                
         Content="Xóa" Width="80"
    HorizontalAlignment="Right" Margin="5"/>
            <Button Grid.Row="5" Grid.Column="4" 
         Content="Thêm" Width="80"
         HorizontalAlignment="Right" Margin="5"/>
        </Grid>
        <ListView Grid.Row="1" Grid.Column="0" Margin="5" BorderThickness="1" BorderBrush="Gray">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="lớp đất" Width="70"/>
                    <GridViewColumn Header="φ" Width="60"/>
                    <GridViewColumn Header="Chiều dày" Width="80"/>
                    <GridViewColumn Header="γ" Width="60"/>
                    <GridViewColumn Header="Độ dính C" Width="90"/>
                    <GridViewColumn Header="Moodun E" Width="80"/>
                    <GridViewColumn Header="Δ" Width="60"/>
                    <GridViewColumn Header="N(SPT)" Width="70"/>
                    <GridViewColumn Header="qc(CPT)" Width="70"/>
                    <GridViewColumn Header="W(%)" Width="70"/>
                    <GridViewColumn Header="Wd(%)" Width="70"/>
                    <GridViewColumn Header="Wch(%)" Width="70"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Button Grid.Row="2" Grid.Column="0" Content="Xác nhận" 
     Width="100" HorizontalAlignment="Right" 
     Margin="10,10,10,10"/>
    </Grid>
</Window>
