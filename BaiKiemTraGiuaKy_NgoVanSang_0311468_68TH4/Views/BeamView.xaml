<Window x:Class="BaiKiemTraGiuaKy_NgoVanSang_0311468_68TH4.BeamView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BaiKiemTraGiuaKy_NgoVanSang_0311468_68TH4"
        xmlns:beamviewmodel="clr-namespace:BaiKiemTraGiuaKy_NgoVanSang_0311468_68TH4.ViewModels"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Window.DataContext>
        <beamviewmodel:BeamViewModel/>
    </Window.DataContext>
    <Grid x:Name="GridA" ShowGridLines="True">
        <!--khai báo bố cục chính-->
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!--1. Nhập liệu dầm-->
        <Grid x:Name="GridA1" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Nhập liệu thông tin dầm-->
            <GroupBox Header="Thông tin" Grid.Column="0">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="Mã hiệu:"/>
                        <TextBox x:Name="txtMark" Width="100" Margin="15 0 0 0" Text="{Binding Mark}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="b (m):"/>
                        <TextBox x:Name="txtb" Width="100" Margin="30 0 0 0" Text="{Binding b}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5" >
                        <Label Content="h (m):"/>
                        <TextBox x:Name="txth" 
                             Text="{Binding h}"
                             Width="100" Margin="30 0 0 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5" >
                        <Label Content="a (m):"/>
                        <TextBox x:Name="txta" 
                             Text="{Binding a}"
                             Width="100" Margin="30 0 0 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5" >
                        <Label Content="M(KN/m):" ToolTip="Nhập Mômen" />
                        <TextBox x:Name="txtM"
                             Text="{Binding M}"
                             Width="100" Margin="8 0 0 0"/>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <GroupBox Header="Vật liệu" Grid.Column="1">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="Bê tông:"/>
                        <ComboBox x:Name="cmb_BeTong" 
                              ItemsSource="{Binding Path=ConcreteMaterialList}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding ConcreteMaterial}"
                              Width="80" 
                              Margin="5 0 0 0" SelectedIndex="1" >


                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="Cốt thép:"/>
                        <ComboBox x:Name="cmb_CotThep" Width="80" 
                              ItemsSource="{Binding Path=RebarMaterialList}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding RebarMaterial}"
                              SelectedIndex="1" >
                        </ComboBox>
                    </StackPanel>

                </StackPanel>
            </GroupBox>

            <GroupBox Header="Thông số" Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="HS điều kiện làm việc:"/>
                        <TextBox x:Name="txt_HSDKLV" Width="50" Margin="40 0 0 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5"  >
                        <Label Content="Hàm lượng cốt thép tối thiểu:"/>
                        <TextBox x:Name="txt_MuMin" Width="50" />
                    </StackPanel>

                </StackPanel>
            </GroupBox>
        </Grid>

        <!--2. Danh sách quản lý dầm-->
        <DataGrid x:Name="dtg_BeamList" Grid.Row="1" ItemsSource="{Binding BeamList, IsAsync=True}" 
              SelectedItem="{Binding CurrentBeam, Mode=TwoWay}"
              AutoGenerateColumns="False" 
              CanUserAddRows="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                <DataGridTextColumn Header="Mã hiệu" Binding="{Binding Mark}" Width="60" />
                <DataGridTextColumn Header="b" Binding="{Binding b}"  />
                <DataGridTextColumn Header="h" Binding="{Binding h }" />
                <DataGridTextColumn Header="a" Binding="{Binding a}" />
                <DataGridTextColumn Header="h0" Binding="{Binding h0}" />
                <DataGridTextColumn Header="M (m)" Binding="{Binding M}" />
                <DataGridTextColumn Header="Aₛ (cm²)" Binding="{Binding As, StringFormat=N2}" />
                <DataGridTextColumn Header="Alpha_M (m)" Binding="{Binding AlphaM, StringFormat=N5}" />
                <DataGridTextColumn Header="Alpha_R (m)" Binding="{Binding AlphaR}" />
                <DataGridTextColumn Header="Bài toán" Binding="{Binding BaiToan}" />
                <DataGridTextColumn Header="Note" Binding="{Binding Note}" />

            </DataGrid.Columns>
            <!--Dùng DataTrigger-->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding BaiToan}" Value="Không thỏa mãn" >
                            <Setter Property="Background" Value="Red"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding BaiToan}" Value="Cốt kép" >
                            <Setter Property="Background" Value="Yellow"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding BaiToan}" Value="Cốt đơn" >
                            <Setter Property="Background" Value="LightBlue"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!--3. Nút chức năng-->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnThemDam" Command="{Binding AddBeamCommand}" Content="Thêm dầm" Width="100"  Height="30"  />
            <Button x:Name="btnXoaDam" Command="{Binding RemoveBeamCommand}" Content="Xóa dầm" Width="100"  Height="30"  Margin="50 0 0 0" />
            <Button x:Name="btnTinhToanDam" Content="Tính toán"  Command="{Binding CalBeamCommand}" Width="100" Margin="50 0 0 0" Height="30" Click="btnTinhToanDam_Click" />
        </StackPanel>
    </Grid>
</Window>
